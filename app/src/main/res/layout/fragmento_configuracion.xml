<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- ── TÍTULO ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_config"
            android:textColor="@color/texto_principal"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <!-- ── TARJETA DE PERFIL ───────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/EstiloCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/text_avatar"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/fondo_avatar"
                    android:gravity="center"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/rojo_primario"
                    android:text="?"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/text_nombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/texto_principal"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/text_rol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_rol_tecnico"
                    android:textColor="@color/rojo_primario"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="@drawable/fondo_badge"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/text_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/texto_secundario"
                    android:textSize="13sp"
                    android:gravity="center"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── SECCIÓN ADMIN: EQUIPO TÉCNICO (gone por defecto) ─── -->
        <LinearLayout
            android:id="@+id/seccion_tecnicos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/fondo_borde"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/seccion_equipo_tecnico"
                android:textColor="@color/rojo_primario"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/lista_tecnicos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_agregar_tecnico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_agregar_tecnico"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/fondo_borde"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- ── SEPARADOR ──────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/fondo_borde"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"/>

        <!-- ── BOTÓN CERRAR SESIÓN ─────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_cerrar_sesion"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_cerrar_sesion"
            android:textColor="@color/rojo_primario"
            android:textSize="15sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/rojo_primario"
            app:strokeWidth="1dp"/>

        <!-- ── FOOTER: VERSIÓN ────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nombre_app"
                android:textColor="@color/texto_muted"
                android:textSize="12sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/version_app"
                android:textColor="@color/texto_muted"
                android:textSize="11sp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
