<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:paddingStart="4dp"
    android:paddingEnd="0dp">

    <TextView
        android:id="@+id/text_avatar_tecnico"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/fondo_avatar"
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/rojo_primario"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/text_nombre_tecnico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_principal"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/text_email_tecnico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_secundario"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/text_rol_tecnico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rojo_primario"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/fondo_badge"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/btn_eliminar_tecnico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✕"
        android:textColor="@color/texto_muted"
        android:textSize="18sp"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"/>

</LinearLayout>
