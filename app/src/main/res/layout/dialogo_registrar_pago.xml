<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <!-- Monto -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_monto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_monto_pago"
        style="@style/EstiloCampo"
        android:layout_marginBottom="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/campo_monto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/texto_principal"
            android:textSize="16sp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Método de pago -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/lbl_metodo_pago"
        android:textColor="@color/texto_secundario"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_metodo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="true"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip android:id="@+id/chip_efectivo"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/metodo_efectivo" style="@style/EstiloChip" android:checked="true"/>
        <com.google.android.material.chip.Chip android:id="@+id/chip_yape"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/metodo_yape" style="@style/EstiloChip"/>
        <com.google.android.material.chip.Chip android:id="@+id/chip_plin"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/metodo_plin" style="@style/EstiloChip"/>
        <com.google.android.material.chip.Chip android:id="@+id/chip_transferencia"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/metodo_transferencia" style="@style/EstiloChip"/>
        <com.google.android.material.chip.Chip android:id="@+id/chip_tarjeta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/metodo_tarjeta" style="@style/EstiloChip"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Nota opcional -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_nota_pago"
        style="@style/EstiloCampo"
        android:layout_marginBottom="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/campo_nota_pago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_principal"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:gravity="top"/>
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
