<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Layout principal de TecrobSys
    ───────────────────────────────────────────────────
    Estructura:
      CoordinatorLayout (raíz — coordina FAB + BottomNav)
        ├── FrameLayout (contenedor de fragmentos)
        └── BottomNavigationView (flotante, tipo píldora)
        └── FAB (botón nueva orden, centrado sobre el nav)

    Diseño flotante: el BottomNav tiene márgenes horizontales y
    verticales para separarse de los bordes, con esquinas redondeadas
    que respetan los bordes curvos de pantallas modernas (ej: S24 Ultra).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal">

    <!--
        Contenedor principal donde se intercambian los fragmentos.
        paddingBottom: deja espacio para el nav flotante + sus márgenes
        (nav ~64dp + margenBottom 16dp + margenTop implícito 16dp = ~96dp)
    -->
    <FrameLayout
        android:id="@+id/contenedor_fragmento"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="96dp"/>

    <!--
        Bottom Navigation View — estilo flotante / píldora.

        layout_marginHorizontal: separa el nav de los bordes laterales,
          respetando las esquinas curvas del S24 Ultra y similares.
        layout_marginBottom: eleva el nav sobre el borde inferior,
          dando espacio a la barra de gestos del sistema.
        background: drawable con esquinas redondeadas (24dp) y borde sutil.
        elevation: sombra suave que distingue el nav del contenido.
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navegacion_inferior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/fondo_nav_inferior"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:menu="@menu/menu_navegacion"
        app:itemIconTint="@color/selector_nav_item"
        app:itemTextColor="@color/selector_nav_item"
        app:labelVisibilityMode="labeled"
        app:elevation="12dp"/>

    <!--
        FAB Central — Botón para crear nueva orden.
        layout_marginBottom: ajustado para centrarse visualmente
          sobre el nav flotante (nav ~64dp + margenBottom 16dp → centro en ~48dp).
        El FAB queda ligeramente por encima del nav, sin ocultarlo.
    -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_nueva_orden"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="44dp"
        android:contentDescription="@string/nav_nueva"
        app:srcCompat="@drawable/ic_agregar"
        app:backgroundTint="@color/rojo_primario"
        app:tint="@color/colorOnPrimary"
        app:fabSize="normal"
        app:elevation="6dp"
        app:pressedTranslationZ="12dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
