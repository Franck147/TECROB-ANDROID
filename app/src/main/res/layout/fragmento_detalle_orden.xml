<?xml version="1.0" encoding="utf-8"?>
<!--
    fragmento_detalle_orden.xml — Detalle completo de una orden
    ─────────────────────────────────────────────────────────────
    Estructura:
      LinearLayout (raíz vertical)
        - TopBar: botón volver + número de orden
        - NestedScrollView
            - Banner de estado
            - Card: datos del cliente (avatar + nombre + teléfono + acciones)
            - Card: datos del equipo
            - Card: totales
            - Card: seguimiento (timeline)
            - Grid de acciones (PDF, WhatsApp, etc.)
            - Botón "Marcar como completada"
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_principal">

    <!-- ── TOP BAR ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:paddingBottom="8dp">

        <!-- Botón volver -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_volver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="18sp"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="@color/texto_principal"
            android:minWidth="0dp"
            android:paddingStart="0dp"/>

        <!-- Número de orden -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/text_numero_orden"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#ORD-0041"
                android:textColor="@color/texto_principal"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/text_fecha_creacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/texto_secundario"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Chip de estado (tappable para cambiar) -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En progreso"
            style="@style/EstiloChip"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- ProgressBar mientras carga -->
    <ProgressBar
        android:id="@+id/progress_cargando"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/rojo_primario"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

    <!-- ── CONTENIDO SCROLLEABLE ─────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/contenido_orden"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- ── CARD: CLIENTE ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_datos_cliente"
                android:textColor="@color/rojo_primario"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/EstiloCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Avatar + nombre + teléfono -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/text_iniciales_cliente"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="CM"
                            android:textColor="@color/rojo_primario"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@drawable/fondo_avatar"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_nombre_cliente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Carlos Mendoza"
                                android:textColor="@color/texto_principal"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/text_telefono_cliente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+51 987 654 321"
                                android:textColor="@color/texto_secundario"
                                android:textSize="12sp"/>

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/fondo_borde"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Botones de acción del cliente -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/boton_llamar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/btn_llamar"
                            android:textSize="12sp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="@color/fondo_borde"
                            android:textColor="@color/estado_progreso_texto"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/boton_whatsapp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/btn_whatsapp"
                            android:textSize="12sp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="@color/fondo_borde"
                            android:textColor="@color/verde_whatsapp"/>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── CARD: EQUIPO ───────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_datos_equipo"
                android:textColor="@color/rojo_primario"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/EstiloCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Tipo + Marca/Modelo en 2 columnas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lbl_tipo"
                                android:textColor="@color/texto_muted"
                                android:textSize="10sp"
                                android:textAllCaps="true"/>
                            <TextView
                                android:id="@+id/text_tipo_equipo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/texto_principal"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lbl_marca_modelo"
                                android:textColor="@color/texto_muted"
                                android:textSize="10sp"
                                android:textAllCaps="true"/>
                            <TextView
                                android:id="@+id/text_marca_modelo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/texto_principal"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Número de serie -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_serie"
                        android:textColor="@color/texto_muted"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:layout_marginBottom="2dp"/>
                    <TextView
                        android:id="@+id/text_serie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/texto_principal"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Problema reportado -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lbl_problema"
                        android:textColor="@color/texto_muted"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/text_desperfecto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/estado_pendiente_texto"
                        android:textSize="13sp"
                        android:background="@color/estado_pendiente_fondo"
                        android:padding="10dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── CARD: TOTALES ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_totales"
                android:textColor="@color/rojo_primario"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/EstiloCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Subtotal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_subtotal"
                            android:textColor="@color/texto_secundario"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/text_subtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/texto_principal"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Descuento -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_descuento"
                            android:textColor="@color/texto_secundario"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/text_descuento"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/texto_principal"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Adelanto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_adelanto"
                            android:textColor="@color/texto_secundario"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/text_adelanto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/estado_progreso_texto"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/fondo_borde"
                        android:layout_marginBottom="10dp"/>

                    <!-- Total a cobrar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/lbl_total_cobrar"
                            android:textColor="@color/texto_principal"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/text_total_cobrar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/rojo_primario"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── GRID DE ACCIONES ───────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_acciones"
                android:textColor="@color/rojo_primario"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="16dp">

                <!-- PDF -->
                <LinearLayout
                    android:id="@+id/boton_pdf"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/fondo_boton_accion"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PDF"
                        android:textColor="@color/rojo_primario"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_enviar_pdf"
                        android:textColor="@color/rojo_primario"
                        android:textSize="11sp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- WhatsApp aviso listo -->
                <LinearLayout
                    android:id="@+id/boton_avisar_listo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp"
                    android:background="@drawable/fondo_boton_accion"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WA"
                        android:textColor="@color/verde_whatsapp"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_avisar_listo"
                        android:textColor="@color/verde_whatsapp"
                        android:textSize="11sp"
                        android:gravity="center"/>
                </LinearLayout>

            </GridLayout>

            <!-- ── BOTÓN MARCAR COMPLETADA ────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/boton_marcar_completada"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_marcar_completada"
                android:textSize="14sp"
                style="@style/EstiloBotonPrimario"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>