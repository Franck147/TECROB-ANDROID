<?xml version="1.0" encoding="utf-8"?>
<!--
    fragmento_nueva_orden.xml — Formulario para crear una orden
    ─────────────────────────────────────────────────────────────
    Secciones:
      1. Cliente (buscar o crear)
      2. Tipo de equipo (chips)
      3. Marca, modelo, serie
      4. Desperfecto + estado general
      5. Prioridad (chips)
      6. Accesorios (chips múltiple)
      7. Contraseña + fecha prometida
      8. Botones guardar / cancelar
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_nueva_orden"
            android:textColor="@color/texto_principal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"/>

        <!-- ══ 1. CLIENTE ═══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/seccion_cliente"
            android:textColor="@color/rojo_primario"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Campo DNI (oculto cuando hay cliente seleccionado) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_dni_busqueda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_buscar_dni"
            style="@style/EstiloCampo"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campo_dni_busqueda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/texto_principal"
                android:textColorHint="@color/texto_muted"
                android:textSize="16sp"
                android:inputType="number"
                android:maxLength="8"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Cargando búsqueda / registro -->
        <ProgressBar
            android:id="@+id/progress_buscando_cliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/rojo_primario"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Card: cliente encontrado en BD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_cliente_encontrado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/rojo_primario"
            app:strokeWidth="1dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/text_nombre_cliente_encontrado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/texto_principal"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/text_telefono_cliente_encontrado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/texto_secundario"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_seleccionar_cliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_seleccionar_cliente"
                    style="@style/EstiloBotonPrimario"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card: cliente no encontrado → formulario de registro -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/contenedor_registro_cliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/fondo_borde"
            app:strokeWidth="1dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_cliente_no_encontrado"
                    android:textColor="@color/texto_secundario"
                    android:textSize="13sp"
                    android:layout_marginBottom="12dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_nombre_nuevo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_nombre"
                    style="@style/EstiloCampo"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campo_nombre_nuevo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/texto_principal"
                        android:textSize="14sp"
                        android:inputType="textPersonName|textCapWords"/>
                </com.google.android.material.textfield.TextInputLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="@string/hint_apellido"
                        style="@style/EstiloCampo">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/campo_apellido_nuevo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/texto_principal"
                            android:textSize="14sp"
                            android:inputType="textPersonName|textCapWords"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_telefono_nuevo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="@string/hint_telefono"
                        style="@style/EstiloCampo">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/campo_telefono_nuevo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/texto_principal"
                            android:textSize="14sp"
                            android:inputType="phone"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_email_cliente"
                    style="@style/EstiloCampo"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campo_email_nuevo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/texto_principal"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_direccion"
                    style="@style/EstiloCampo"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/campo_direccion_nuevo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/texto_principal"
                        android:textSize="14sp"
                        android:inputType="textPostalAddress|textCapSentences"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_registrar_cliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_registrar_cliente"
                    style="@style/EstiloBotonPrimario"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Cliente ya seleccionado (visible tras elegir o registrar) -->
        <LinearLayout
            android:id="@+id/contenedor_cliente_seleccionado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"
            android:visibility="gone">

            <!-- Fila nombre + botón Cambiar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/text_nombre_cliente_sel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/texto_principal"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_cambiar_cliente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_cambiar_cliente"
                    android:textSize="12sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/fondo_borde"
                    android:textColor="@color/texto_secundario"/>
            </LinearLayout>

            <!-- Fila teléfono + botón Editar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/text_telefono_cliente_sel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/texto_secundario"
                    android:textSize="14sp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_editar_telefono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_editar_telefono"
                    android:textSize="11sp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="@color/fondo_borde"
                    android:textColor="@color/texto_secundario"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ 2. TIPO DE EQUIPO ════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/seccion_equipo"
            android:textColor="@color/rojo_primario"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_equipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">
                <com.google.android.material.chip.Chip android:id="@+id/chip_laptop"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equipo_laptop" style="@style/EstiloChip" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_computadora"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equipo_pc" style="@style/EstiloChip"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_impresora"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equipo_impresora" style="@style/EstiloChip"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_tablet"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equipo_tablet" style="@style/EstiloChip"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_celular"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equipo_celular" style="@style/EstiloChip"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_otro"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/equipo_otro" style="@style/EstiloChip"/>
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- ══ 3. DATOS DEL EQUIPO ══════════════════════════════ -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_marca"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:hint="@string/hint_marca" style="@style/EstiloCampo">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campo_marca"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/texto_principal" android:textSize="14sp"
                    android:inputType="textCapCharacters"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                android:hint="@string/hint_modelo" style="@style/EstiloCampo">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campo_modelo"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/texto_principal" android:textSize="14sp"
                    android:inputType="textCapCharacters"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_serie" style="@style/EstiloCampo"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campo_serie"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/texto_principal" android:textSize="14sp"
                android:inputType="textCapCharacters"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══ 4. DESPERFECTO ═══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/seccion_desperfecto"
            android:textColor="@color/rojo_primario" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_desperfecto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_desperfecto" style="@style/EstiloCampo"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campo_desperfecto"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:minLines="3" android:gravity="top"
                android:textColor="@color/texto_principal" android:textSize="14sp"
                android:inputType="textMultiLine|textCapCharacters"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/hint_descripcion_general" style="@style/EstiloCampo"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/campo_descripcion"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:minLines="2" android:gravity="top"
                android:textColor="@color/texto_principal" android:textSize="14sp"
                android:inputType="textMultiLine|textCapCharacters"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══ 5. PRIORIDAD ════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/seccion_prioridad"
            android:textColor="@color/rojo_primario" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_prioridad"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            app:singleSelection="true" app:selectionRequired="true"
            android:layout_marginBottom="16dp">
            <com.google.android.material.chip.Chip android:id="@+id/chip_baja"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/prioridad_baja" style="@style/EstiloChip"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_normal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/prioridad_normal" style="@style/EstiloChip" android:checked="true"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_alta"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/prioridad_alta" style="@style/EstiloChip"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_urgente"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/prioridad_urgente" style="@style/EstiloChip"/>
        </com.google.android.material.chip.ChipGroup>

        <!-- ══ 6. ACCESORIOS ═══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/seccion_accesorios"
            android:textColor="@color/rojo_primario" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_accesorios"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <com.google.android.material.chip.Chip android:id="@+id/chip_funda"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/accesorio_funda" style="@style/EstiloChipAccesorio"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_mouse"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/accesorio_mouse" style="@style/EstiloChipAccesorio"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_cargador"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/accesorio_cargador" style="@style/EstiloChipAccesorio"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_mochila"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/accesorio_mochila" style="@style/EstiloChipAccesorio"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_cable_datos"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/accesorio_cable_datos" style="@style/EstiloChipAccesorio"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_estabilizador"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/accesorio_estabilizador" style="@style/EstiloChipAccesorio"/>
        </com.google.android.material.chip.ChipGroup>

        <!-- ══ 7. SERVICIOS ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/seccion_servicios"
            android:textColor="@color/rojo_primario" android:textSize="11sp"
            android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/contenedor_servicios_seleccionados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_agregar_servicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_agregar_servicio_orden"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/fondo_borde"
            android:textColor="@color/texto_secundario"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:id="@+id/seccion_subtotal_servicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lbl_subtotal_servicios"
                android:textColor="@color/texto_secundario"
                android:textSize="13sp"/>
            <TextView
                android:id="@+id/text_subtotal_servicios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/ 0.00"
                android:textColor="@color/rojo_primario"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ══ 8. DATOS EXTRA ══════════════════════════════════ -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:hint="@string/hint_contrasena_equipo" style="@style/EstiloCampo">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campo_contrasena"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/texto_principal" android:textSize="14sp"
                    android:inputType="textCapCharacters"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                android:hint="@string/hint_fecha_prometida" style="@style/EstiloCampo"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_today"
                app:endIconTint="@color/texto_secundario">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campo_fecha_prometida"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/texto_principal" android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- ProgressBar mientras guarda -->
        <ProgressBar
            android:id="@+id/progress_guardando"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="@color/rojo_primario"
            android:visibility="gone" android:layout_marginBottom="8dp"/>

        <!-- ══ 8. BOTONES ══════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_guardar"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="@string/btn_guardar_orden"
            style="@style/EstiloBotonPrimario"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/boton_cancelar"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="@string/btn_cancelar"
            style="@style/EstiloBotonSecundario"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>